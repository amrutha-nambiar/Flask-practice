from flask import Flask
app = Flask(__name__)

@app.route('/')
def home():
    return "Welcome to the College Portal."

@app.route('/courses')
def courses():
    return "Available Courses: Python, Java, Web Development."

@app.route('/student/<name>')
def student(name):
    return f"Hello {name}, welcome to the student section."

app.run(debug=True)